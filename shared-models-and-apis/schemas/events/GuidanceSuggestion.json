{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GuidanceSuggestion",
  "description": "Cloud-side guidance suggestion produced from deviations, search results, and teaching assets.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "suggestion_id",
    "session_id",
    "suggestion_type",
    "title",
    "message",
    "priority",
    "created_at"
  ],
  "properties": {
    "suggestion_id": {
      "type": "string",
      "minLength": 1
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "source_event_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "target_scope": {
      "type": "string",
      "enum": [
        "teacher_console",
        "edge_robot",
        "operator"
      ]
    },
    "suggestion_type": {
      "type": "string",
      "enum": [
        "instruction",
        "warning",
        "reset",
        "checklist",
        "review_card"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "message": {
      "type": "string",
      "minLength": 1
    },
    "rationale": {
      "type": "string"
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "linked_card_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "label",
          "command_type"
        ],
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1
          },
          "command_type": {
            "type": "string",
            "enum": [
              "display_message",
              "request_reset",
              "pause_session",
              "resume_session"
            ]
          },
          "payload": {
            "type": "object",
            "additionalProperties": true,
            "default": {}
          }
        }
      },
      "default": []
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    }
  },
  "examples": [
    {
      "suggestion_id": "guide_placement_fix_001",
      "session_id": "sess_20260327_001",
      "source_event_ids": [
        "evt_deviation_cycle1_final_place"
      ],
      "target_scope": "teacher_console",
      "suggestion_type": "review_card",
      "title": "Review final placement before next cycle",
      "message": "Show the placement failure card and ask the operator to confirm left-right target zones before release.",
      "rationale": "The last cycle failed the final placement validation with high confidence.",
      "priority": "high",
      "linked_card_ids": [
        "card_assembly_left_right_001"
      ],
      "actions": [
        {
          "label": "Open deviation card",
          "command_type": "display_message",
          "payload": {
            "card_id": "card_assembly_left_right_001"
          }
        },
        {
          "label": "Request reset after review",
          "command_type": "request_reset",
          "payload": {
            "target_scope": "edge_robot"
          }
        }
      ],
      "created_at": "2026-03-27T09:36:05Z",
      "expires_at": null
    }
  ]
}
