{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DeviationEvent",
  "description": "Deviation or anomaly raised by the supervision pipeline.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "session_id",
    "deviation_type",
    "severity",
    "summary",
    "observed_at"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "task_node_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "deviation_type": {
      "type": "string",
      "enum": [
        "object_missing",
        "order_mismatch",
        "timeout",
        "placement_error",
        "safety_attention",
        "quality_risk"
      ]
    },
    "severity": {
      "type": "string",
      "enum": [
        "info",
        "warning",
        "critical"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "recommended_action": {
      "type": "string"
    },
    "related_event_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "media_object_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "metrics": {
      "type": "object",
      "additionalProperties": {
        "type": "number"
      },
      "default": {}
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "examples": [
    {
      "event_id": "evt_deviation_cycle1_final_place",
      "session_id": "sess_20260327_001",
      "task_node_id": "cycle1_final_placement",
      "deviation_type": "placement_error",
      "severity": "warning",
      "summary": "Final placement failed the left-right validation rule.",
      "description": "Both finished parts remained on the left side after the final placement step.",
      "confidence": 0.94,
      "recommended_action": "Replay the final segment and issue a reset or coaching instruction before the next cycle.",
      "related_event_ids": [
        "evt_progress_cycle1_final_place"
      ],
      "media_object_ids": [
        "media_frame_failure_001",
        "media_clip_placement_failure"
      ],
      "metrics": {
        "left_count": 2,
        "right_count": 0,
        "motion_norm": 0.08
      },
      "observed_at": "2026-03-27T09:35:41Z"
    }
  ]
}
