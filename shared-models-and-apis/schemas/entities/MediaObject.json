{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MediaObject",
  "description": "Registered media artifact that can be replayed, searched, or attached to guidance and teaching cards.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "media_object_id",
    "session_id",
    "kind",
    "purpose",
    "uri",
    "content_type",
    "created_at"
  ],
  "properties": {
    "media_object_id": {
      "type": "string",
      "minLength": 1
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "enum": [
        "image",
        "video",
        "audio",
        "document",
        "archive"
      ]
    },
    "purpose": {
      "type": "string",
      "enum": [
        "evidence",
        "replay_clip",
        "teaching_asset",
        "upload_source"
      ]
    },
    "uri": {
      "type": "string",
      "format": "uri"
    },
    "content_type": {
      "type": "string",
      "minLength": 1
    },
    "filename": {
      "type": [
        "string",
        "null"
      ]
    },
    "checksum_sha256": {
      "type": [
        "string",
        "null"
      ]
    },
    "byte_size": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "start_offset_sec": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0
    },
    "end_offset_sec": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "examples": [
    {
      "media_object_id": "media_clip_placement_failure",
      "session_id": "sess_20260327_001",
      "kind": "video",
      "purpose": "replay_clip",
      "uri": "s3://embodied-supervisor/sessions/sess_20260327_001/clips/placement_failure.mp4",
      "content_type": "video/mp4",
      "filename": "placement_failure.mp4",
      "checksum_sha256": "e3b0c44298fc1c149afbf4c8996fb924",
      "byte_size": 1843200,
      "start_offset_sec": 84.5,
      "end_offset_sec": 88.8,
      "created_at": "2026-03-27T09:36:10Z"
    }
  ]
}
